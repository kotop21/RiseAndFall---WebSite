---
const { isSticky = false } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname.replace(/\/$/, '');

const isHome = path === base;
const isLeaderboard = path.startsWith(`${base}/leaderboard`);
const isWiki = path.startsWith(`${base}/wiki`);
---

<header class:list={["header-wrapper", { sticky: isSticky }]}>
    <div class="topbar">
        <div class="logo">Rise And Fall <span>Community</span></div>
        <nav class="nav-links">
            <a href={`${base}/`} class={isHome ? "active" : ""}>Главная</a>
            <a href={`${base}/leaderboard/`} class={isLeaderboard ? "active" : ""}>Рейтинговая таблица</a>
            <a href={`${base}/wiki/`} class={isWiki ? "active" : ""}>Вики</a>
        </nav>
    </div>
</header>

<style>
.header-wrapper {
    width: 100%;
    z-index: 1000;
}

.sticky {
    position: sticky;
    top: 0;
    background: rgba(15, 15, 15, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 2rem;
    max-width: 1500px;
    margin: 0 auto;
    width: 100%;
}

.logo {
    font-size: 1.4rem;
    font-weight: bold;
    color: var(--fg);
    letter-spacing: 0.05em;
}

.logo span {
    color: var(--accent);
}

.nav-links {
    display: flex;
    gap: 1.5rem;
}

.nav-links a {
    border-bottom: 1px solid transparent;
}

.nav-links a.active {
    color: var(--accent);
    border-color: var(--accent);
    opacity: 1;
}

@media (max-width: 768px) {
    .logo {
        display: none;
    }
    .topbar {
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
    }
    .nav-links {
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }
}
</style>
