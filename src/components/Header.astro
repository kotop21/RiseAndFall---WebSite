---
const { isSticky = false } = Astro.props;
const pathname = Astro.url.pathname;
---

<header class:list={["header-wrapper", { sticky: isSticky }]}>
    <div class="topbar">
        <div class="logo">Rise And Fall <span>Community</span></div>
        <nav class="nav-links">
            <a href="/" class={pathname === "/" ? "active" : ""}>Главная</a>
            <a href="/leaderboard" class={pathname.startsWith("/leaderboard") ? "active" : ""}>Рейтинговая таблица</a>
            <a href="/wiki" class={pathname.startsWith("/wiki") ? "active" : ""}>Вики</a>
        </nav>
    </div>
</header>

<style>
    .header-wrapper {
        width: 100%;
        z-index: 1000;
    }

    .sticky {
        position: sticky;
        top: 0;
        background: rgba(15, 15, 15, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 2rem;
        max-width: 1500px;
        margin: 0 auto;
        width: 100%;
    }

    .logo {
        font-size: 1.4rem;
        font-weight: bold;
        color: var(--fg);
        letter-spacing: 0.05em;
    }

    .logo span {
        color: var(--accent);
    }

    .nav-links {
        display: flex;
        gap: 1.5rem;
    }

    .nav-links a.active {
        color: var(--accent);
        border-color: var(--accent);
        opacity: 1;
    }

    @media (max-width: 768px) {
        .logo {
            display: none;
        }
        .topbar {
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
        }
        .nav-links {
            flex-wrap: wrap;
            justify-content: center;
            gap: 1rem;
        }
    }
</style>
