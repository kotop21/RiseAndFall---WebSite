---
import '@styles/global.css';
import Header from '@components/Header.astro';

const files = Object.values(import.meta.glob('@docs/*.md', { eager: true }));
const base = import.meta.env.BASE_URL;

const allPages = files.map((f: any) => {
    const slug = f.file.split('/').pop().replace('.md', '');
    return { slug, title: f.frontmatter.title || slug };
});
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Вики | Rise and Fall</title>
    </head>
    <body>
        <Header />
        <main class="wiki-index">
            <div class="card-grid">
                {allPages.map(page => (
                    <a href={`${base}/wiki/${page.slug}`} class="card">
                        <h2>{page.title}</h2>
                        <p>Читать статью ↗</p>
                    </a>
                ))}
            </div>
        </main>
    </body>
</html>

<style>
    .wiki-index {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2rem;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.2s;
        border-top: 3px solid var(--accent);
    }

    .card:hover {
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-2px);
    }

    .card h2 {
        color: var(--fg);
        margin: 0 0 1rem 0;
        font-size: 1.2rem;
    }

    .card p {
        color: #888;
        margin: 0;
        font-size: 0.9rem;
    }

    @media (max-width: 768px) {
        .wiki-index {
            padding: 2rem 1rem;
        }
        .card-grid {
            grid-template-columns: 1fr;
        }
        .card {
            padding: 1.5rem;
        }
    }
</style>
