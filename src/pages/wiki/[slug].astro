---
import '@styles/global.css';
import Header from '@components/Header.astro';

export async function getStaticPaths() {
    const files = Object.values(import.meta.glob('@docs/*.md', { eager: true }));
    
    return files.map((file: any) => {
        const slug = file.file.split('/').pop().replace('.md', '');
        return {
            params: { slug },
            props: { currentFile: file, allFiles: files }
        };
    });
}

const { currentFile, allFiles } = Astro.props;
const { Content, frontmatter, getHeadings } = currentFile;
const headings = getHeadings();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPages = allFiles.map((f: any) => {
    const s = f.file.split('/').pop().replace('.md', '');
    return { slug: s, title: f.frontmatter.title || s };
});

const currentSlug = Astro.params.slug;
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
        <title>{frontmatter.title} | Wiki</title>
    </head>
    <body>
        <Header isSticky={true} />

        <div class="wiki-layout">
            <aside class="left-sidebar">
                <div class="sidebar-content">
                    <h3>Все статьи</h3>
                    <nav class="doc-links">
                        {allPages.map(page => (
                            <a 
                                href={`${base}/wiki/${page.slug}/`} 
                                class={currentSlug === page.slug ? "active" : ""}
                            >
                                {page.title}
                            </a>
                        ))}
                    </nav>
                </div>
            </aside>

            <main class="markdown-container">
                <article class="markdown-content">
                    <Content />
                </article>
            </main>

            <aside class="right-sidebar">
                <div class="sticky-toc">
                    <h3>На этой странице</h3>
                    <nav class="toc-links">
                        {headings.map(heading => (
                            <a href={`#${heading.slug}`} class={`depth-${heading.depth}`}>
                                {heading.text}
                            </a>
                        ))}
                    </nav>
                </div>
            </aside>
        </div>
    </body>
</html>

<style>
    .wiki-layout {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr) 260px;
        gap: 40px;
        max-width: 1600px;
        margin: 0 auto;
        padding: 40px 20px;
        align-items: start;
    }

    /* Левая колонка */
    .left-sidebar {
        position: sticky;
        top: 80px;
        height: fit-content;
        max-height: calc(100vh - 100px);
        overflow-y: auto;
    }

    .sidebar-content h3 {
        color: var(--fg);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .doc-links {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .doc-links a {
        color: #888;
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s;
    }

    .doc-links a:hover, .doc-links a.active {
        color: var(--accent);
    }

    .doc-links a.active {
        font-weight: 600;
    }

    /* Центральная колонка */
    .markdown-container {
        min-width: 0; /* Важно для предотвращения раздувания грида от pre/code */
    }

    .markdown-content {
        color: #ccc;
        line-height: 1.6;
    }

    .markdown-content :global(h1) { color: var(--accent); font-size: 2.2rem; margin-bottom: 1.5rem; }
    .markdown-content :global(h2) { 
        color: var(--fg); 
        font-size: 1.5rem; 
        margin: 2.5rem 0 1rem; 
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .markdown-content :global(pre) {
        background: #0d0d0d !important;
        padding: 1.5rem;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.05);
        overflow-x: auto;
        margin: 1.5rem 0;
    }

    .markdown-content :global(code) {
        font-family: 'JetBrains Mono', monospace;
        background: rgba(255,255,255,0.05);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
    }

    .markdown-content :global(ul) {
        padding-left: 1.2rem;
        margin-bottom: 1.5rem;
    }

    .markdown-content :global(li) {
        margin-bottom: 0.5rem;
    }

    /* Правая колонка */
    .right-sidebar {
        position: sticky;
        top: 80px;
        height: fit-content;
    }

    .sticky-toc {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        padding: 20px;
        border-radius: 12px;
    }

    .sticky-toc h3 {
        font-size: 0.8rem;
        text-transform: uppercase;
        margin-bottom: 15px;
        opacity: 0.4;
    }

    .toc-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .toc-links a {
        color: #666;
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.2s;
    }

    .toc-links a:hover { color: var(--accent); }
    .depth-3 { margin-left: 15px; font-size: 0.8rem; }

    /* Адаптивность */
    @media (max-width: 1200px) {
        .wiki-layout {
            grid-template-columns: 240px 1fr;
        }
        .right-sidebar { display: none; }
    }

    @media (max-width: 900px) {
        .wiki-layout {
            display: block;
            padding: 20px;
        }
        .left-sidebar {
            position: static;
            margin-bottom: 40px;
            max-height: none;
        }
    }
</style>
