---
import '@styles/global.css';
import Header from '@components/Header.astro';

export async function getStaticPaths() {
    const files = Object.values(import.meta.glob('@docs/*.md', { eager: true }));
    
    return files.map((file: any) => {
        const slug = file.file.split('/').pop().replace('.md', '');
        return {
            params: { slug },
            props: { currentFile: file, allFiles: files }
        };
    });
}

const { currentFile, allFiles } = Astro.props;
const { Content, frontmatter, getHeadings } = currentFile;
const headings = getHeadings();

const allPages = allFiles.map((f: any) => {
    const s = f.file.split('/').pop().replace('.md', '');
    return { slug: s, title: f.frontmatter.title || s };
});
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
        <title>{frontmatter.title} | Wiki</title>
    </head>
    <body>
        <Header isSticky={true} />

        <div class="wiki-layout">
            <aside class="left-sidebar">
                <h3>Все статьи</h3>
                <nav class="doc-links">
                    {allPages.map(page => (
                        <a href={`/wiki/${page.slug}`} class={Astro.params.slug === page.slug ? "active" : ""}>
                            {page.title}
                        </a>
                    ))}
                </nav>
            </aside>

            <aside class="right-sidebar">
                <div class="sticky-toc">
                    <nav class="toc-links">
                        {headings.map(heading => (
                            <a 
                                href={`#${heading.slug}`} 
                                class={`depth-${heading.depth}`}
                            >
                                {heading.text}
                            </a>
                        ))}
                    </nav>
                </div>
            </aside>

            <main class="markdown-content">
                <Content />
            </main>
        </div>
    </body>
</html>

<style>
    .wiki-layout {
        font-size: 15px;
        display: grid;
        grid-template-columns: 250px minmax(0, 1fr) 250px;
        gap: 3rem;
        max-width: 1500px;
        margin: 0 auto;
        padding: 2rem;
        align-items: start;
    }

    .left-sidebar {
        position: sticky;
        top: 5rem;
        max-height: calc(100vh - 6rem);
        overflow-y: auto;
        padding-right: 1rem;
        grid-row: 1;
        grid-column: 1;
    }

    .left-sidebar::-webkit-scrollbar,
    .sticky-toc::-webkit-scrollbar {
        width: 4px;
    }

    .left-sidebar::-webkit-scrollbar-thumb,
    .sticky-toc::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }

    aside h3 {
        color: var(--fg);
        font-size: 1.1rem;
        margin-top: 0;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 0.5rem;
    }

    .doc-links {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .doc-links a {
        color: #888;
        font-size: 0.95rem;
    }

    .doc-links a.active {
        color: var(--accent);
        font-weight: bold;
    }

    .markdown-content {
        color: var(--fg);
        line-height: 1.7;
        min-width: 0;
        word-wrap: break-word;
        overflow-wrap: break-word;
        grid-row: 1;
        grid-column: 2;
    }

    .markdown-content :global(h1),
    .markdown-content :global(h2),
    .markdown-content :global(h3),
    .markdown-content :global(h4) {
        scroll-margin-top: 80px;
    }

    .markdown-content :global(h1) {
        color: var(--accent);
        font-size: 2.5rem;
        margin-top: 0;
        margin-bottom: 2rem;
        word-break: break-word;
    }

    .markdown-content :global(h2) {
        font-size: 1.8rem;
        margin-top: 3rem;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
        padding-bottom: 0.5rem;
    }

    .markdown-content :global(h3) { font-size: 1.2rem; }
    .markdown-content :global(h4) { font-size: 0.9rem; }

    .markdown-content :global(p) {
        color: #A1A1AA;
        margin-bottom: 1.5rem;
    }

    .markdown-content :global(pre) {
        padding: 1.2rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: #111 !important;
        margin: 1.5rem 0;
        max-width: 100%;
        overflow-x: auto;
        white-space: pre;
        word-spacing: normal;
        word-break: normal;
    }

    .markdown-content :global(code) {
        font-family: ui-monospace, 'SF Mono', Consolas, monospace;
        background: rgba(255, 255, 255, 0.1);
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.9em;
        word-break: break-all;
    }

    .markdown-content :global(pre code) {
        background: transparent !important;
        padding: 0;
        font-size: 0.95em;
        color: inherit;
        border: none !important;
        word-break: normal;
        display: block;
    }

    .markdown-content :global(ul), .markdown-content :global(ol) {
        padding-left: 1.5rem;
        color: #A1A1AA;
        margin-bottom: 1.5rem;
    }

    .right-sidebar {
        position: sticky;
        top: 5rem;
        max-height: calc(100vh - 6rem);
        height: fit-content;
        grid-row: 1;
        grid-column: 3;
    }

    .sticky-toc {
        background: rgba(15, 15, 15, 0.5);
        padding: 0.8rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        overflow-y: auto;
        max-height: inherit;
    }

    .toc-links {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .toc-links a {
        color: #A1A1AA;
        font-size: 0.85rem;
        line-height: 1.4;
        white-space: normal;
        word-wrap: break-word;
    }

    .toc-links a:hover {
        color: var(--accent);
    }

    .depth-1 { margin-left: 0; font-weight: bold; color: var(--fg) !important; font-size: 0.9rem !important; }
    .depth-2 { margin-left: 0.8rem; }
    .depth-3 { margin-left: 1.5rem; font-size: 0.8rem !important; }
    .depth-4 { margin-left: 2.2rem; font-size: 0.75rem !important; opacity: 0.8; }

    @media (max-width: 1024px) {
        .wiki-layout {
            grid-template-columns: 200px minmax(0, 1fr);
        }
        .right-sidebar {
            display: none;
        }
    }

    @media (max-width: 768px) {
        .wiki-layout {
            display: flex;
            flex-direction: column;
            padding: 1rem;
            width: 100vw;
            overflow-x: hidden;
            margin-top: 0;
        }
        .left-sidebar {
            display: none;
        }
        .right-sidebar {
            display: block;
            position: static;
            max-height: none;
            width: 100%;
            max-width: none;
            margin-bottom: 2rem;
            order: -1;
        }
        .sticky-toc {
            position: static;
            max-height: none;
            background: rgba(255, 255, 255, 0.02);
        }
        .markdown-content {
            padding: 0 5px;
        }
        .markdown-content :global(h1),
        .markdown-content :global(h2),
        .markdown-content :global(h3),
        .markdown-content :global(h4) {
            scroll-margin-top: 120px;
        }
        .markdown-content :global(h1) {
            font-size: 1.8rem;
        }
        .markdown-content :global(pre) {
            margin: 1rem -5px;
            border-radius: 0;
            width: calc(100% + 10px);
        }
    }
</style>```
